# ════════════════════════════════════════════
#  MegaTraveller — קובץ הגדרות
#  העתק ל-.env והכנס את הערכים שלך
# ════════════════════════════════════════════

# ── חובה ────────────────────────────────────
# מפתח Claude API: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── מקורות מחיר (מומלץ מאוד) ────────────────
# Amadeus — API רשמי לטיסות ומלונות (חינמי)
# הרשמה: https://developers.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# ── ערוצי התראה ──────────────────────────────

# 1. ntfy.sh — פוש לנייד, ללא חשבון (הכי פשוט!)
#    אפליקציה: https://ntfy.sh
#    פתח → Subscribe topic → הכנס שם ייחודי
NTFY_TOPIC=megatraveller-שמך

# 2. Telegram — הודעות לבוט
#    צור בוט: @BotFather בטלגרם → /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=123456789

# 3. WhatsApp — דרך Twilio
#    הרשמה: https://twilio.com → Sandbox for WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+972501234567

# 4. Email — Gmail (צור App Password)
#    Gmail → Security → 2FA → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
ALERT_EMAIL=yourmail@gmail.com

# 5. Discord — Webhook
#    Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── אופציונלי ────────────────────────────────
# Open Exchange Rates — שערי חליפין (חינמי)
# https://openexchangerates.org
OPENEXCHANGERATES_KEY=
